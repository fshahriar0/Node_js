doctype html
html
  head
    title Add Movie
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    .container.mt-5
      h1.mb-4 New movie

      form(action="/movies", method="POST")
        .mb-3
          input.form-control(type="text", name="title", placeholder="Title", required)

        .mb-3
          input.form-control(type="text", name="director", placeholder="Director", required)

        .mb-3
          input.form-control(type="number", name="year", placeholder="Year", required)

        button.btn.btn-primary(type="submit") Add