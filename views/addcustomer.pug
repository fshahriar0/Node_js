doctype html
html
  head
    title Add Customer
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    .container.mt-5
      h1 Add Customer

      form(action="/add", method="POST")
        .mb-3
          input.form-control(type="text", name="firstname", placeholder="First Name", required)
        .mb-3
          input.form-control(type="text", name="lastname", placeholder="Last Name", required)
        .mb-3
          input.form-control(type="email", name="email", placeholder="Email", required)
        .mb-3
          input.form-control(type="text", name="phone", placeholder="Phone", required)

        button.btn.btn-success(type="submit") Add